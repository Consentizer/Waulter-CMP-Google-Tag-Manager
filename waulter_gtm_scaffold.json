      {
        "variableId": "1003",
        "name": "Waulter - Web Analytics Allowed",
        "type": "jsm",
        "parameter": [
          {
            "type": "TEMPLATE",
            "key": "javascript",
            "value": "function() {\n  var purposes = {{Waulter_Purposes}};\n  if (Array.isArray(purposes)) {\n    return purposes.includes(\"PU061\") || purposes.includes(\"PU046\") || purposes.includes(\"PU050\");\n  }\n  return false;\n}"
          }
        ],
        "parentFolderId": "1000",
        "formatValue": {}
