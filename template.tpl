scenarios:
- name: Default consent state is set correctly
  code: |
    const mockData = {
      waulterId: 'SC00045',
      sdkUrl: 'https://cdn.waulter.cz/sdk.js',
      waitForUpdate: '500',
      adsDataRedaction: true,
      urlPassthrough: false
    };

    mock('logToConsole', function() {});
    mock('addEventCallback', function() {});
    mock('copyFromDataLayer', function() { return undefined; });

    let defaultConsentArgs;
    mock('setDefaultConsentState', function(arg) {
      defaultConsentArgs = arg;
    });
    mock('updateConsentState', function() {});
    mock('gtagSet', function() {});
    mock('setInWindow', function() {});
    mock('copyFromWindow', function() { return undefined; });
    mock('makeNumber', function(v) { return v * 1; });
    mock('getType', function(v) { return typeof v; });
    mock('injectScript', function(url, onSuccess) { onSuccess(); });

    runCode(mockData);

    assertThat(defaultConsentArgs.ad_storage).isEqualTo('denied');
    assertThat(defaultConsentArgs.ad_user_data).isEqualTo('denied');
    assertThat(defaultConsentArgs.ad_personalization).isEqualTo('denied');
    assertThat(defaultConsentArgs.analytics_storage).isEqualTo('denied');
    assertThat(defaultConsentArgs.functionality_storage).isEqualTo('denied');
    assertThat(defaultConsentArgs.personalization_storage).isEqualTo('denied');
    assertThat(defaultConsentArgs.security_storage).isEqualTo('granted');
    assertThat(defaultConsentArgs.wait_for_update).isEqualTo(500);
    assertApi('gtmOnSuccess').wasCalled();
